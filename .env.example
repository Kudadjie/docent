# Docent — environment variable reference
# Copy to .env (or export in your shell) to override config.toml values.
# All variables are optional; omit any you don't need.

# --- LLM API keys ---
DOCENT_ANTHROPIC_API_KEY=sk-ant-...
DOCENT_OPENAI_API_KEY=sk-...

# --- Default model (litellm model string) ---
# DOCENT_DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# --- Reading tool ---
# Path to your local Paper Database folder (Mendeley watch folder).
# DOCENT_READING__DATABASE_DIR=/path/to/Paper Database

# Mendeley collection that defines reading-queue membership.
# DOCENT_READING__QUEUE_COLLECTION=Docent-Queue

# Override the Mendeley MCP command (JSON array, space-separated).
# DOCENT_READING__MENDELEY_MCP_COMMAND=uvx mendeley-mcp

# --- Output ---
# DOCENT_VERBOSE=false
# DOCENT_NO_COLOR=false
